{
  "name": "@librecommunications/wincap",
  "version": "0.0.1",
  "description": "Native Windows screen capture with audio for Electron — WGC + WASAPI loopback (C++/N-API)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "src/",
    "prebuilds/",
    "CMakeLists.txt",
    "scripts/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:native": "cmake-js compile --runtime=electron --runtime-version=41.1.0 --arch=x64",
    "build:native:node": "cmake-js compile --arch=x64",
    "build:ts": "tsc -p tsconfig.json",
    "build": "npm run build:native && npm run build:ts",
    "prebuild": "node scripts/prebuild.js",
    "clean": "rimraf build dist prebuilds",
    "test": "vitest run",
    "test:unit": "ctest --test-dir build --output-on-failure",
    "lint": "eslint src/ts test"
  },
  "binary": {
    "napi_versions": [8]
  },
  "dependencies": {
    "node-addon-api": "^8.2.0",
    "node-gyp-build": "^4.8.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "cmake-js": "^7.3.0",
    "prebuildify": "^6.0.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "os": [
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LibreCommunications/wincap.git"
  },
  "license": "AGPL-3.0-or-later",
  "author": "LibreCommunications"
}
