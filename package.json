{
  "name": "@librecord/wincap",
  "version": "0.1.0",
  "description": "Native Windows screen capture with audio for Electron — WGC + WASAPI loopback (Rust/napi-rs)",
  "main": "lib.js",
  "types": "lib.d.ts",
  "napi": {
    "name": "wincap",
    "triples": {
      "defaults": false,
      "additional": [
        "x86_64-pc-windows-msvc",
        "aarch64-pc-windows-msvc"
      ]
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "lib.js",
    "lib.d.ts",
    "src/",
    "crates/",
    "Cargo.toml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "napi build --platform --release --cargo-cwd crates/wincap-napi",
    "build:debug": "napi build --platform --cargo-cwd crates/wincap-napi",
    "prepublishOnly": "napi prepublish -t npm",
    "clean": "rimraf *.node dist"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0",
    "rimraf": "^6.0.1"
  },
  "engines": {
    "node": ">=18"
  },
  "os": [
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LibreCommunications/wincap.git"
  },
  "license": "AGPL-3.0-or-later",
  "author": "LibreCommunications"
}
